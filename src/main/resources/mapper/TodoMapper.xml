<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.itheima.todo.mapper.TodoMapper">

    <!-- 查询所有 -->
    <select id="findAll" resultType="com.itheima.todo.entity.Todo">
        SELECT id, content, completed FROM todo
    </select>

    <!-- 新增 -->
    <insert id="add">
        INSERT INTO todo(content, completed)
        VALUES(#{content}, 0)
    </insert>

    <!-- 标记完成 -->
    <update id="complete">
        UPDATE todo SET completed = 1 WHERE id = #{id}
    </update>

    <!-- 删除 -->
    <delete id="delete">
        DELETE FROM todo WHERE id = #{id}
    </delete>

</mapper>